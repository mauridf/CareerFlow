{
  "Application": {
    "Environment": "Production",
    "Url": "https://careerflow-api.onrender.com",
    "ShowDetailedErrors": false,
    "CorsOrigins": [
      "https://careerflow.vercel.app",
      "https://careerflow.netlify.app"
    ]
  },

  "Database": {
    "ConnectionString": "Host=${DB_HOST};Port=${DB_PORT};Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD};Trust Server Certificate=true;"
  },

  "Redis": {
    "Enabled": true,
    "ConnectionString": "${REDIS_CONNECTION_STRING}",
    "DefaultCacheDurationMinutes": 15
  },

  "Jwt": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Error",
        "Microsoft.EntityFrameworkCore": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/careerflow-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  }
}
