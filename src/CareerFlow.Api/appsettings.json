{
  "Application": {
    "Name": "CareerFlow",
    "Environment": "Development",
    "Url": "http://localhost:5000",
    "CorsOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:4200"
    ]
  },

  "Jwt": {
    "SecretKey": "#{JWT_SECRET_KEY}#", // Substituir por variável de ambiente JWT_SECRET_KEY
    "Issuer": "careerflow-api",
    "Audience": "careerflow-app",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },

  "Database": {
    "Provider": "PostgreSQL",
    "ConnectionString": "Host=localhost;Port=5432;Database=careerflow;Username=postgres;Password=Mt190720@;Include Error Detail=true;"
  },

  "Redis": {
    "Enabled": false,
    "ConnectionString": "localhost:6379,password=redisdev,defaultDatabase=0",
    "InstanceName": "CareerFlow:",
    "DefaultCacheDurationMinutes": 10
  },

  "Storage": {
    "Provider": "Local",
    "LocalPath": "uploads",
    "MaxFileSizeMB": 5,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ]
  },

  "RateLimiting": {
    "Global": {
      "PermitLimit": 100,
      "WindowSeconds": 60
    },
    "Login": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    },
    "Register": {
      "PermitLimit": 3,
      "WindowSeconds": 3600
    }
  },

  "Email": {
    "SmtpHost": "#{SMTP_HOST}#", // Substituir por variável de ambiente SMTP_HOST
    "SmtpPort": 587,
    "SmtpUsername": "#{SMTP_USERNAME}#", // Substituir por variável de ambiente SMTP_USERNAME
    "SmtpPassword": "#{SMTP_PASSWORD}#", // Substituir por variável de ambiente SMTP_PASSWORD
    "FromName": "CareerFlow",
    "FromEmail": "#{SMTP_FROM_EMAIL}#", // Substituir por variável de ambiente SMTP_FROM_EMAIL
    "UseSsl": false,
    "FrontendUrl": "http://localhost:3000"
  },

  "Pdf": {
    "LicenseType": "Community",
    "MaxGenerationTimeSeconds": 30,
    "MaxFileSizeMB": 5,
    "DefaultFont": "Arial"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithCorrelationId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/careerflow-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },

  "AllowedHosts": "*"
}
