# ============================================
# CareerFlow - Variáveis de Ambiente
# ============================================

# Ambiente
ASPNETCORE_ENVIRONMENT=Development
APPLICATION_NAME=CareerFlow
APPLICATION_URL=http://localhost:5000

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=careerflow
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_CONNECTION_STRING=Host=localhost;Port=5432;Database=careerflow;Username=postgres;Password=postgres;Include Error Detail=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redisdev
REDIS_CONNECTION_STRING=localhost:6379,password=redisdev

# JWT
JWT_SECRET_KEY=careerflow-super-secret-key-dev-only-change-in-production-min-512-bits
JWT_ISSUER=careerflow-api
JWT_AUDIENCE=careerflow-app
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000;http://localhost:5173

# Serilog
SERILOG_MINIMUM_LEVEL=Information